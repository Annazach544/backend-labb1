<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mina kurser</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<header>
    <nav>
        <a href="/">Mina kurser</a>
        <a href="/add">Lägg till kurs</a>
        <a href="/about">Om webbplatsen</a>
    </nav>
</header>

<main>
    <h1>Mina kurser</h1>
    <p class="intro">Här visas de kurser som är sparade i databasen.</p>

    <% if(courses.length === 0) { %>

        <p>Inga kurser lagrade ännu.</p>

    <% } else { %>

        <ul class="course-list">
            <% courses.forEach(course => { %>
                <li class="course-item">
                    <h2><%= course.coursecode %></h2>
                    <p><strong>Kursnamn:</strong> <%= course.coursename %></p>
                    <p><strong>Progression:</strong> <%= course.progression %></p>
                    <p>
                        <strong>Kursplan:</strong>
                        <a href="<%= course.syllabus %>" target="_blank">Visa kursplan</a>
                    </p>
                    <a class="delete-link" href="/delete/<%= course.id %>">Radera kurs</a>
                </li>
            <% }) %>
        </ul>

    <% } %>
</main>

<footer>
    <p>Laboration 1 - Serverbaserad webbutveckling</p>
</footer>

</body>
</html>